# =============================================================================
# Rust
# =============================================================================

# Compiled output
debug/
target/

# Backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds — debugging symbols
*.pdb

# Cargo lock is committed for binaries, not libraries
# (keep Cargo.lock for this workspace since it produces binaries)

# cargo-mutants output
**/mutants.out
**/mutants.out.old
**/mutants.out*/

# cargo-fuzz
fuzz/target/

# cargo-tarpaulin coverage reports
tarpaulin-report.html
cobertura.xml
lcov.info
coverage/

# cargo-flamegraph / perf profiling
perf.data
perf.data.old
flamegraph.svg

# cargo-audit
audit.json

# cargo-geiger
geiger-report.json

# =============================================================================
# Build artifacts
# =============================================================================

# Incremental compilation artefacts
**/*.d

# Static / shared libs accidentally left behind
*.so
*.dylib
*.dll
*.a
*.lib

