# Git LFS — track generated GIF demos so they don't bloat the repo history
*.gif filter=lfs diff=lfs merge=lfs -text

# Explicitly cover the crate-level VHS generated output directories
crates/flashkraft-gui/examples/vhs/generated/*.gif filter=lfs diff=lfs merge=lfs -text
crates/flashkraft-tui/examples/vhs/generated/*.gif filter=lfs diff=lfs merge=lfs -text
